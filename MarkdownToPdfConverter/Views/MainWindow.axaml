<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MarkdownToPdfConverter.ViewModels"
        x:Class="MarkdownToPdfConverter.Views.MainWindow"
        Title="{Binding WindowTitle}"
        MinWidth="800" MinHeight="600"
        Background="{Binding Background}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="#252525" BorderBrush="{Binding BorderBrush}" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{Binding UploadButtonText}"
                        Command="{Binding UploadFileCommand}"
                        Margin="5" Padding="15,8"
                        Background="Transparent" Foreground="White"
                        BorderBrush="#555555" BorderThickness="1" />

                <Rectangle Width="1" Height="20" Fill="#555555" Margin="10,0"/>

                <Button Content="{Binding ConvertButtonText}"
                        Command="{Binding ConvertToPdfCommand}"
                        IsEnabled="{Binding CanConvert}"
                        Margin="5" Padding="15,8"
                        Background="#03A9F4" Foreground="White"
                        BorderThickness="0" />

                <Rectangle Width="1" Height="20" Fill="#555555" Margin="10,0"/>

                <Button Content="{Binding LanguageButtonText}"
                        Command="{Binding SwitchLanguageCommand}"
                        Margin="5" Padding="15,8"
                        Background="Transparent" Foreground="White"
                        BorderBrush="#555555" BorderThickness="1" />

                <Rectangle Width="1" Height="20" Fill="#555555" Margin="10,0"/>

                <Button Content="Theme"
                        Command="{Binding SwitchThemeCommand}"
                        Margin="5" Padding="15,8"
                        Background="Transparent" Foreground="White"
                        BorderBrush="#555555" BorderThickness="1" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="{Binding FileTabText}">
                <ScrollViewer Padding="20">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedFileText}" FontWeight="Bold" FontSize="18"
                                   Foreground="{Binding Foreground}" Margin="0,0,0,10"/>
                        <Border Background="{Binding BorderBrush}" CornerRadius="4" Padding="10">
                            <TextBlock Text="{Binding SelectedFilePath}" TextWrapping="Wrap"
                                      Foreground="{Binding TextBoxForeground}" FontSize="14"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding EditTabText}">
                <Grid ColumnDefinitions="*,10,*,200">
                    <Border Grid.Column="0" Background="{Binding BorderBrush}" CornerRadius="4" Padding="5">
                        <TextBox Text="{Binding MarkdownText}"
                                AcceptsReturn="True"
                                Watermark="{Binding EditContentText}"
                                Background="{Binding TextBoxBackground}"
                                Foreground="{Binding TextBoxForeground}"
                                BorderThickness="0"
                                FontSize="{Binding FontSize}"
                                Padding="10" />
                    </Border>

                    <Border Grid.Column="2" Background="{Binding BorderBrush}" CornerRadius="4" Padding="5">
                        <ScrollViewer>
                            <TextBlock Text="{Binding MarkdownText}"
                                       TextWrapping="Wrap"
                                       Foreground="{Binding TextBoxForeground}"
                                       FontSize="{Binding FontSize}"
                                       Padding="10" />
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="3" Background="#333333" CornerRadius="4" Padding="10" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Settings" FontWeight="Bold" FontSize="16" Foreground="White" Margin="0,0,0,10"/>
                            <Slider Minimum="12" Maximum="24" Value="{Binding FontSize}" />
                            <TextBlock Text="{Binding FontSize, StringFormat='Font Size: {0}'}" Foreground="White" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Margin="10" Padding="10" CornerRadius="4"
                Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding Foreground}" FontSize="14"/>
        </Border>
    </Grid>
</Window>